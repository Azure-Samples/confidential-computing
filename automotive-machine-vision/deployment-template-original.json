{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "containerGroupName": { "type": "string" },
    "location": { "type": "string", "defaultValue": "[resourceGroup().location]" },
    "appImage": { "type": "string" },
    "registryServer": { "type": "string" },
    "registryUsername": { "type": "string" },
    "registryPassword": { "type": "securestring" },
    "dnsNameLabel": { "type": "string" },
    "flaskSecretKey": { "type": "securestring", "defaultValue": "replace-me" }
  },
  "resources": [
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerGroupName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": "Confidential",
        "confidentialComputeProperties": {
          "ccePolicy": ""
        },
        "containers": [
          {
            "name": "automotive-machine-vision",
            "properties": {
              "image": "[parameters('appImage')]",
              "ports": [{ "protocol": "TCP", "port": 443 }],
              "resources": {
                "requests": {
                  "memoryInGB": 6,
                  "cpu": 2
                }
              },
              "environmentVariables": [
                { "name": "FLASK_SECRET_KEY", "secureValue": "[parameters('flaskSecretKey')]" },
                { "name": "MAA_ENDPOINT", "value": "sharedeus.eus.attest.azure.net" }
              ]
            }
          }
        ],
        "imageRegistryCredentials": [
          {
            "server": "[parameters('registryServer')]",
            "username": "[parameters('registryUsername')]",
            "password": "[parameters('registryPassword')]"
          }
        ],
        "ipAddress": {
          "ports": [{ "protocol": "TCP", "port": 443 }],
          "type": "Public",
          "dnsNameLabel": "[parameters('dnsNameLabel')]"
        },
        "osType": "Linux",
        "restartPolicy": "Always"
      }
    }
  ],
  "outputs": {
    "fqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName'))).ipAddress.fqdn]"
    }
  }
}
