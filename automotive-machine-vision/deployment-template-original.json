{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "containerGroupName": { "type": "string" },
    "location": { "type": "string", "defaultValue": "[resourceGroup().location]" },
    "appImage": { "type": "string" },
    "registryServer": { "type": "string" },
    "registryUsername": { "type": "string" },
    "registryPassword": { "type": "securestring" },
    "dnsNameLabel": { "type": "string" },
    "flaskSecretKey": { "type": "securestring", "defaultValue": "replace-me" },
    "tlsCertificatePem": { "type": "securestring", "defaultValue": "" },
    "tlsPrivateKeyPem": { "type": "securestring", "defaultValue": "" },
    "cpuCores": { "type": "int", "defaultValue": 2 },
    "memoryInGB": { "type": "int", "defaultValue": 6 },
    "processingWorkers": { "type": "string", "defaultValue": "3" },
    "detectEveryNFrames": { "type": "string", "defaultValue": "2" },
    "instanceName": { "type": "string", "defaultValue": "automotive-machine-vision" },
    "peerEndpoints": { "type": "string", "defaultValue": "" }
  },
  "resources": [
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerGroupName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": "Confidential",
        "confidentialComputeProperties": {
          "ccePolicy": ""
        },
        "containers": [
          {
            "name": "automotive-machine-vision",
            "properties": {
              "image": "[parameters('appImage')]",
              "ports": [
                { "protocol": "TCP", "port": 80 },
                { "protocol": "TCP", "port": 443 }
              ],
              "resources": {
                "requests": {
                  "memoryInGB": "[parameters('memoryInGB')]",
                  "cpu": "[parameters('cpuCores')]"
                }
              },
              "environmentVariables": [
                { "name": "FLASK_SECRET_KEY", "secureValue": "[parameters('flaskSecretKey')]" },
                { "name": "TLS_CERT_PEM", "secureValue": "[parameters('tlsCertificatePem')]" },
                { "name": "TLS_KEY_PEM", "secureValue": "[parameters('tlsPrivateKeyPem')]" },
                { "name": "MAA_ENDPOINT", "value": "sharedeus.eus.attest.azure.net" },
                { "name": "PROCESSING_WORKERS", "value": "[parameters('processingWorkers')]" },
                { "name": "DETECT_EVERY_N_FRAMES", "value": "[parameters('detectEveryNFrames')]" },
                { "name": "INSTANCE_NAME", "value": "[parameters('instanceName')]" },
                { "name": "PEER_ENDPOINTS", "value": "[parameters('peerEndpoints')]" }
              ]
            }
          }
        ],
        "imageRegistryCredentials": [
          {
            "server": "[parameters('registryServer')]",
            "username": "[parameters('registryUsername')]",
            "password": "[parameters('registryPassword')]"
          }
        ],
        "ipAddress": {
          "ports": [
            { "protocol": "TCP", "port": 80 },
            { "protocol": "TCP", "port": 443 }
          ],
          "type": "Public",
          "dnsNameLabel": "[parameters('dnsNameLabel')]"
        },
        "osType": "Linux",
        "restartPolicy": "Always"
      }
    }
  ],
  "outputs": {
    "fqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName'))).ipAddress.fqdn]"
    }
  }
}
